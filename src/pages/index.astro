---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const features = [
  {
    title: "ARを用いた介護DXサービスがトヨタ自動車および文部科学大臣より評価され、表彰されました。",
    date: "2026/05/09",
    href: "https://dcon.ai/teams/kamiyama2026/",
  },
  {
    title: "介護現場特化のARシステム開発で事業評価額2億4000万円を認定されました。",
    date: "2026/05/09",
    href: "https://dcon.ai/teams/kamiyama2026/",
  },
  {
    title: "県庁に表敬しました",
    date: "2026/05/22",
    href: "https://x.com/preftokushima/status/2057692326873739371?s=20",
  },
];
---

<BaseLayout
  title="Codell | 現場DXの実装パートナー"
  description="Codellは、現場DXの導入・実装・拡張・保守を一気通貫で支援するパートナーです。ARデバイスなども必要に応じて取り入れます。"
>
  <Header homeHref="#top" />

  <main id="top">
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero-media" aria-hidden="true">
        <img src="/assets/main_visual.jpg" alt="" />
      </div>
      <div class="hero-overlay"></div>
      <div class="hero-inner">
        <div class="hero-text">
          <p class="eyebrow">Field DX Implementation</p>
          <h1 id="hero-title">現場を、<br /><span class="hero-line"><span class="accent">もう一度</span>設計する。</span></h1>
          <span class="hero-en">We design field DX, from setup to operation.</span>
          <div class="hero-actions">
            <a class="button primary" href="/contact/">導入を相談する</a>
            <a class="button secondary" href="#strength">できることを見る</a>
          </div>
          <div class="hero-meta">SCROLL ↓</div>
        </div>
      </div>
    </section>

    <section class="section intro" id="about">
      <div class="section-label">About Codell</div>
      <div class="intro-grid">
        <h2>気づきを、資産に変える。</h2>
        <p>
          Codellは、AIなどの最新技術を用いて、あなたの現場を変えるパートナーです。
          現場の緻密なヒアリングから、最適な解決策をご提案します。
        </p>
      </div>
    </section>

    <section class="section strength" id="strength" aria-labelledby="strength-title">
      <div class="section-heading">
        <div class="section-label">Strength</div>
        <h2 id="strength-title">Codellができること</h2>
        <p>現場に寄り添い、設計から運用まで一気通貫で伴走します。</p>
      </div>
      <div class="strength-grid">
        <article>
          <span class="card-index">01</span>
          <h3>0から伴走</h3>
          <p>現場ヒアリングから入り、業務システムの設計段階から支援します。</p>
        </article>
        <article>
          <span class="card-index">02</span>
          <h3>最新技術への対応</h3>
          <p>AIやARなどの最新技術に精通。最適な手段を提案します。</p>
        </article>
        <article>
          <span class="card-index">03</span>
          <h3>継続支援</h3>
          <p>システム実装後の運用・保守・改善まで伴走します。</p>
        </article>
      </div>
    </section>

    <section class="section process" id="process" aria-labelledby="process-title">
      <div class="section-heading">
        <div class="section-label">Process</div>
        <h2 id="process-title">初回相談から公開までの流れ</h2>
        <p>ヒアリングから保守・改善まで、4ステップで現場DXを実装します。</p>
      </div>
      <ol class="process-list">
        <li>
          <span>1</span>
          <h3>現場整理</h3>
          <p>利用シーン、課題、既存業務、導入体制を確認し、優先順位を合わせます。</p>
        </li>
        <li>
          <span>2</span>
          <h3>導入設計</h3>
          <p>デバイス、初期設定、説明内容、スケジュールを整理して提案します。</p>
        </li>
        <li>
          <span>3</span>
          <h3>導入・拡張</h3>
          <p>現場で使い始められる状態をつくり、必要に応じて機能を拡張します。</p>
        </li>
        <li>
          <span>4</span>
          <h3>保守・改善</h3>
          <p>運用中の相談、トラブル対応、アップデートを継続して支援します。</p>
        </li>
      </ol>
    </section>

    <section class="section works" id="works" aria-labelledby="works-title">
      <div class="section-heading">
        <div class="section-label">Works</div>
        <h2 id="works-title">実績</h2>
        <p>Codellのこれまでの取り組みと認定。</p>
      </div>
      <ul class="features-list">
        {features.map((feature) => (
          <li class="feature-item feature-item--clickable">
            <a href={feature.href} target="_blank" rel="noreferrer">
              <time class="feature-date" datetime={feature.date.replaceAll("/", "-")}>{feature.date}</time>
              <p class="feature-title">{feature.title}</p>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="section company" id="company" aria-labelledby="company-title">
      <div>
        <div class="section-label">Company</div>
        <h2 id="company-title">会社情報</h2>
      </div>
      <dl class="company-table">
        <div>
          <dt>名称</dt>
          <dd>Codell</dd>
        </div>
        <div>
          <dt>設立日</dt>
          <dd>登記申請準備中</dd>
        </div>
        <div>
          <dt>事業内容</dt>
          <dd>現場DXの導入・実装・拡張・運用保守、アプリ開発、ARデバイス販売</dd>
        </div>
        <div>
          <dt>所在地</dt>
          <dd>徳島県名西郡神山町神領大埜地299-1</dd>
        </div>
        <div>
          <dt>お問い合わせ</dt>
          <dd>codell.support@gmail.com</dd>
        </div>
      </dl>
    </section>

    <section class="contact" id="contact" aria-labelledby="contact-title">
      <div class="contact-intro">
        <div class="section-label">Contact</div>
        <h2 id="contact-title">現場DXを始めるなら、まずは課題の整理から。</h2>
        <p>
          「何から手を付ければよいか」「現場で続けられるか」など、検討の最初期からご相談ください。
        </p>
        <dl class="contact-meta">
          <div><dt>Email</dt><dd>codell.support@gmail.com</dd></div>
          <div><dt>Address</dt><dd>徳島県名西郡神山町神領大埜地299-1</dd></div>
        </dl>
      </div>
      <div class="contact-cta">
        <a class="button primary light" href="/contact/">お問い合わせフォームへ</a>
      </div>
    </section>
  </main>

  <Footer homeHref="#top" />
</BaseLayout>
