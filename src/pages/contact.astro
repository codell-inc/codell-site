---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="お問い合わせ | Codell"
  description="Codellへのお問い合わせ。現場DXの導入・運用に関するご相談はこちらから。"
  bodyClass="page-contact"
  includeEmailJs
>
  <Header />

  <main id="top">
    <section class="contact-page">
      <div class="contact-page-head">
        <p class="eyebrow">Contact</p>
        <h1>お問い合わせ</h1>
        <p class="lead">
          現場DXの導入・運用に関するご相談は、こちらのフォームよりお気軽にお寄せください。
          内容を確認のうえ、担当者よりご連絡いたします。
        </p>
        <dl class="contact-meta light">
          <div><dt>Email</dt><dd>codell.support@gmail.com</dd></div>
          <div><dt>Address</dt><dd>徳島県名西郡神山町神領大埜地299-1</dd></div>
        </dl>
      </div>

      <form class="contact-form light" id="contact-form" novalidate>
        <div class="field">
          <label for="contact-name">お名前 <span aria-hidden="true">*</span></label>
          <input type="text" id="contact-name" name="name" autocomplete="name" required />
        </div>
        <div class="field">
          <label for="contact-email">メールアドレス <span aria-hidden="true">*</span></label>
          <input type="email" id="contact-email" name="email" autocomplete="email" required />
        </div>
        <div class="field">
          <label for="contact-type">問い合わせ種別 <span aria-hidden="true">*</span></label>
          <select id="contact-type" name="type" required>
            <option value="" disabled selected>選択してください</option>
            <option value="依頼">依頼</option>
            <option value="その他">その他</option>
          </select>
        </div>
        <div class="field">
          <label for="contact-message">問い合わせ内容 <span aria-hidden="true">*</span></label>
          <textarea id="contact-message" name="message" rows="6" required></textarea>
        </div>
        <div class="form-foot">
          <p class="form-status" id="contact-status" role="status" aria-live="polite"></p>
          <button type="submit" class="button primary" id="contact-submit">送信する</button>
        </div>
      </form>
    </section>
  </main>

  <Footer />
</BaseLayout>
